<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.FormResepObatController"
            stylesheets="@style.css">

    <!-- TITLE -->
    <top>
        <VBox alignment="CENTER"
              spacing="15"
              styleClass="top-panel">
            <padding>
                <Insets top="20"
                        right="20"
                        bottom="10"
                        left="20"/>
            </padding>
            <Label text="FORM RESEP OBAT"
                   styleClass="title"/>
        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <VBox alignment="CENTER"
              spacing="25">
            <padding>
                <Insets top="10"
                        right="30"
                        bottom="20"
                        left="30"/>
            </padding>

            <GridPane alignment="CENTER"
                      hgap="20"
                      vgap="18">

                <!-- COLUMN WIDTH -->
                <columnConstraints>
                    <ColumnConstraints minWidth="120"/>
                    <ColumnConstraints minWidth="220"/>
                </columnConstraints>

                <!-- ROW 1 -->
                <Label text="ID Resep"/>
                <TextField fx:id="txtId"
                           editable="false"
                           prefWidth="220"
                           GridPane.columnIndex="1"/>

                <!-- ROW 2 -->
                <Label text="Pilih Pemeriksaan"
                       GridPane.rowIndex="1"/>
                <ComboBox fx:id="cbPemeriksaan"
                          prefWidth="220"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="1"/>

                <!-- ROW 3 -->
                <Label text="Pilih Obat"
                       GridPane.rowIndex="2"/>
                <ComboBox fx:id="cbObat"
                          prefWidth="220"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="2"/>

                <!-- ROW 4 -->
                <Label text="Jumlah"
                       GridPane.rowIndex="3"/>
                <TextField fx:id="txtJumlah"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>

                <!-- ROW 5 -->
                <Label text="Dosis"
                       GridPane.rowIndex="4"/>
                <TextField fx:id="txtDosis"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="4"/>

                <!-- ROW 6 -->
                <Label text="Keterangan"
                       GridPane.rowIndex="5"/>
                <TextArea fx:id="txtKeterangan"
                          prefWidth="220"
                          prefHeight="100"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="5"/>

            </GridPane>

            <!-- BUTTON -->
            <HBox alignment="CENTER"
                  spacing="20">
                <Button fx:id="btnSimpan"
                        text="Simpan"
                        onAction="#handleSimpan"
                        styleClass="btn-save"
                        prefWidth="120"
                        prefHeight="40"
                        contentDisplay="LEFT"
                        graphicTextGap="8">
                    <graphic><Label styleClass="icon-mi" text="&#xE161;"/></graphic>
                </Button>

                <Button text="Batal"
                        onAction="#handleBatal"
                        styleClass="btn-cancel"
                        prefWidth="120"
                        prefHeight="40"
                        contentDisplay="LEFT"
                        graphicTextGap="8">
                    <graphic><Label styleClass="icon-mi" text="&#xE5CD;"/></graphic>
                </Button>
            </HBox>
        </VBox>
    </center>

</BorderPane>
