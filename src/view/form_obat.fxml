<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.FormObatController"
            stylesheets="@style.css">

    <!-- TITLE -->
    <top>
        <VBox alignment="CENTER"
              spacing="15"
              styleClass="top-panel">
            <padding>
                <Insets top="20"
                        right="20"
                        bottom="10"
                        left="20"/>
            </padding>
            <Label text="FORM DATA OBAT"
                   styleClass="title"/>
        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <VBox alignment="CENTER"
              spacing="25">
            <padding>
                <Insets top="10"
                        right="30"
                        bottom="20"
                        left="30"/>
            </padding>

            <GridPane alignment="CENTER"
                      hgap="20"
                      vgap="18">

                <!-- COLUMN WIDTH -->
                <columnConstraints>
                    <ColumnConstraints minWidth="120"/>
                    <ColumnConstraints minWidth="220"/>
                </columnConstraints>

                <!-- ROW 1 -->
                <Label text="ID Obat"/>
                <TextField fx:id="txtId"
                           editable="false"
                           prefWidth="220"
                           GridPane.columnIndex="1"/>

                <!-- ROW 2 -->
                <Label text="Nama Obat"
                       GridPane.rowIndex="1"/>
                <TextField fx:id="txtNama"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <!-- ROW 3 -->
                <Label text="Stok Obat"
                       GridPane.rowIndex="2"/>
                <TextField fx:id="txtStok"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="2"/>

                <!-- ROW 4 -->
                <Label text="Harga (Rp)"
                       GridPane.rowIndex="3"/>
                <TextField fx:id="txtHarga"
                           prefWidth="220"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>

            </GridPane>

            <!-- BUTTON -->
            <HBox alignment="CENTER"
                  spacing="20">
                <Button text="💾 Simpan"
                        fx:id="btnSimpan"
                        onAction="#handleSimpan"
                        styleClass="btn-save"
                        prefWidth="120"
                        prefHeight="40"/>

                <Button text="✖ Batal"
                        onAction="#handleBatal"
                        styleClass="btn-cancel"
                        prefWidth="120"
                        prefHeight="40"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
