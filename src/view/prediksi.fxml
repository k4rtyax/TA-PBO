<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.PrediksiController"
            stylesheets="@style.css">

    <!-- TOP -->
    <top>
        <VBox alignment="CENTER"
              spacing="5"
              styleClass="top-panel">
            <padding>
                <Insets top="20" right="20" bottom="15" left="20"/>
            </padding>
            <Label text="PREDIKSI RISIKO DIABETES"
                   styleClass="title"
                   maxWidth="Infinity"
                   alignment="CENTER"
                   contentDisplay="LEFT"
                   graphicTextGap="8">
                <graphic><Label styleClass="icon-mi" text="&#xEA4A;"/></graphic>
            </Label>
            <Label text="Masukkan data medis pasien untuk memprediksi risiko diabetes"
                   styleClass="subtitle"
                   maxWidth="Infinity"
                   alignment="CENTER"/>
        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding>
                <Insets top="20" right="40" bottom="20" left="40"/>
            </padding>

            <!-- INPUT GRID -->
            <GridPane alignment="CENTER" hgap="20" vgap="14">
                <columnConstraints>
                    <ColumnConstraints minWidth="180"/>
                    <ColumnConstraints minWidth="200"/>
                    <ColumnConstraints minWidth="180"/>
                    <ColumnConstraints minWidth="200"/>
                </columnConstraints>

                <!-- ROW 0 -->
                <Label text="Kehamilan (Pregnancies)"
                       styleClass="label-form"/>
                <TextField fx:id="txtPregnancies"
                           promptText="contoh: 2"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="1"/>

                <Label text="Glukosa (Glucose)"
                       styleClass="label-form"
                       GridPane.columnIndex="2"/>
                <TextField fx:id="txtGlucose"
                           promptText="contoh: 120"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="3"/>

                <!-- ROW 1 -->
                <Label text="Tekanan Darah (mmHg)"
                       styleClass="label-form"
                       GridPane.rowIndex="1"/>
                <TextField fx:id="txtBloodPressure"
                           promptText="contoh: 80"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>

                <Label text="Ketebalan Kulit (mm)"
                       styleClass="label-form"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="1"/>
                <TextField fx:id="txtSkinThickness"
                           promptText="contoh: 20"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="1"/>

                <!-- ROW 2 -->
                <Label text="Insulin (mu U/ml)"
                       styleClass="label-form"
                       GridPane.rowIndex="2"/>
                <TextField fx:id="txtInsulin"
                           promptText="contoh: 80"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="2"/>

                <Label text="BMI"
                       styleClass="label-form"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="2"/>
                <TextField fx:id="txtBMI"
                           promptText="contoh: 25.5"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="2"/>

                <!-- ROW 3 -->
                <Label text="Riwayat Keluarga (DPF)"
                       styleClass="label-form"
                       GridPane.rowIndex="3"/>
                <TextField fx:id="txtDPF"
                           promptText="contoh: 0.5"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="3"/>

                <Label text="Umur (Tahun)"
                       styleClass="label-form"
                       GridPane.columnIndex="2"
                       GridPane.rowIndex="3"/>
                <TextField fx:id="txtAge"
                           promptText="contoh: 33"
                           prefWidth="200"
                           styleClass="modern-field"
                           GridPane.columnIndex="3"
                           GridPane.rowIndex="3"/>

            </GridPane>

            <!-- BUTTON PREDIKSI -->
            <HBox alignment="CENTER" spacing="15">
                <Button text="Prediksi Sekarang"
                        onAction="#handlePrediksi"
                        styleClass="btn-primary"
                        prefWidth="200"
                        prefHeight="42"
                        contentDisplay="LEFT"
                        graphicTextGap="8">
                    <graphic><Label styleClass="icon-mi" text="&#xE8B6;"/></graphic>
                </Button>
                <Button text="Reset"
                        onAction="#handleReset"
                        styleClass="btn-secondary"
                        prefWidth="120"
                        prefHeight="42"
                        contentDisplay="LEFT"
                        graphicTextGap="8">
                    <graphic><Label styleClass="icon-mi" text="&#xE5D5;"/></graphic>
                </Button>
                <Button text="Tutup"
                        onAction="#handleTutup"
                        styleClass="btn-danger"
                        prefWidth="120"
                        prefHeight="42"
                        contentDisplay="LEFT"
                        graphicTextGap="8">
                    <graphic><Label styleClass="icon-mi" text="&#xE5CD;"/></graphic>
                </Button>
            </HBox>

            <!-- HASIL PREDIKSI -->
            <VBox alignment="CENTER" spacing="8" styleClass="card-form">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>
                <Label text="HASIL PREDIKSI"
                       styleClass="section-title"/>
                <Label fx:id="lblHasil"
                       text="-"
                       wrapText="true"
                       maxWidth="Infinity"
                       alignment="CENTER"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                <Label fx:id="lblProbabilitas"
                       text=""
                       style="-fx-font-size: 15px; -fx-text-fill: #64748b;"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>
